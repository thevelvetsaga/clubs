---
import '@/styles/style.css'
import '@/styles/geometry.css'
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { getCollection } from 'astro:content';
import favicon from '@/assets/favicon.png';

const clubs = await getCollection("clubs");

const iconModules = import.meta.glob<{ default: ImageMetadata }>('/src/assets/icons/*.{png,svg,jpg,jpeg}', { eager: true });
const iconMap = Object.fromEntries(
	Object.entries(iconModules).map(([filePath, module]) => {
		const key = filePath.split('/').at(-1)?.replace(/\.(png|svg|jpg|jpeg)$/, '') ?? '';
		return [key, module.default];
	})
);

const clubsSorted = [...clubs].sort((a, b) =>
	a.data.name.localeCompare(b.data.name, undefined, { sensitivity: 'base' })
);

const totalCount = clubs.length;
const clubsCount = clubs.filter((e) => e.data.classification.organization.includes('Club')).length;
const teamsCount = clubs.filter((e) => e.data.classification.organization.includes('Team')).length;

const categories = ['STEM', 'Cultural', 'Humanities', 'IEEE'] as const;
const categoryCounts = Object.fromEntries(
	categories.map((category) => [
		category,
		clubs.filter((e) => e.data.classification.category.includes(category)).length,
	])
);
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" href="/favicon.png" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>clubs.amrita.town</title>
	</head>
	<body>
		<div style="display: flex; flex-direction: row; gap: 1rem; align-items: center; justify-content: left; margin-bottom: 0rem;" >
			<Image src={favicon} alt="clubs logo" format="png" style="height: 67px; width: 67px; image-rendering: pixelated; margin-left: -0.5rem" />
			<h1>clubs</h1>
		</div>
		<p>brought to you by the folks at <a href="https://amrita.town">amrita.town</a>. This is an unofficial students maintained registry of clubs, teams, and communities at Amrita Vishwa Vidyapeetham, Bengaluru</p>
		
		<div style="margin-bottom: 1.5rem; display: flex; flex-wrap: wrap; gap: 3rem">
			<div>
				<p style="margin-bottom: 0.5rem;">Type</p>
				<div class="filter-group" role="group" aria-label="Filter by organization type">
					<button class="filter-btn active" data-filter-type="organization" data-value="all">All</button>
					<button class="filter-btn" data-filter-type="organization" data-value="club">Clubs</button>
					<button class="filter-btn" data-filter-type="organization" data-value="team">Teams</button>
				</div>
			</div>
			<div>
				<p style="margin-bottom: 0.5rem;">Category</p>
				<div class="filter-group" role="group" aria-label="Filter by category">
					<button class="filter-btn active" data-filter-type="category" data-value="all">All</button>
					<button class="filter-btn" data-filter-type="category" data-value="stem">STEM</button>
					<button class="filter-btn" data-filter-type="category" data-value="cultural">Cultural</button>
					<button class="filter-btn" data-filter-type="category" data-value="humanities">Humanities</button>
					<button class="filter-btn" data-filter-type="category" data-value="ieee">IEEE</button>
				</div>
			</div>
		</div>
		
		<div class="clubs-grid" id="clubs-grid">
			{clubsSorted.map(e => (
				(() => {
					const icon = iconMap[e.id] ?? favicon;
					const {theme_color_light, theme_color_dark } = e.data;
					return (
				<a 
					href={`/${e.id}`} 
					class="club-container"
					data-org-type={e.data.classification.organization.map((v) => v.toLowerCase()).join(',')}
					data-category={e.data.classification.category.map((v) => v.toLowerCase()).join(',')}
				>
					<div class="club-info">
						<p>
							<b style={`--accent-light: ${theme_color_light || 'var(--text)'}; --accent-dark: ${theme_color_dark || theme_color_light || 'var(--text)'}; color: light-dark(var(--accent-light), var(--accent-dark));`}>
								{e.data.name}
							</b>
						</p>
						<small>{e.data.description}</small>
					</div>
					<Image
					src={icon}
					class="club-favicon"
					alt={e.data.name + " icon"}
					format="png"
					style={"height: 67px; width: 67px;" + (icon === favicon ? "image-rendering: pixelated;" : "")}
				/>
				</a>
					);
				})()
			))
			}
		</div>

		<footer style="margin-top: 2rem; text-align: center;">
			<p style="margin: 0; font-size: 1rem; line-height: 1.5; font-weight: 500;">
				<strong>Total</strong>: {totalCount}
				<span aria-hidden="true"> | </span>
				<strong>Clubs</strong>: {clubsCount}
				<span aria-hidden="true"> • </span>
				<strong>Teams</strong>: {teamsCount}
			</p>
			<p style="margin: 0.15rem 0 0; font-size: 0.97rem; line-height: 1.5; opacity: 0.95;">
				<strong>STEM</strong>: {categoryCounts.STEM}
				<span aria-hidden="true"> • </span>
				<strong>Cultural</strong>: {categoryCounts.Cultural}
				<span aria-hidden="true"> • </span>
				<strong>Humanities</strong>: {categoryCounts.Humanities}
				<span aria-hidden="true"> • </span>
				<strong>IEEE</strong>: {categoryCounts.IEEE}
			</p>
			<p style="margin: 0.35rem 0 0; font-size: 0.99rem;">
				Are you in charge of a club? <a href="/update"><strong>Update</strong></a> your club's info!
			</p>
		</footer>
		
		<script>
			const filterButtons = document.querySelectorAll('.filter-btn');
			const clubContainers = document.querySelectorAll<HTMLElement>('.club-container');
			
			let selectedOrg = 'all';
			let selectedCategory = 'all';
			
			function filterClubs() {
				clubContainers.forEach(container => {
					const orgTypes = (container.getAttribute('data-org-type') || '').split(',');
					const categories = (container.getAttribute('data-category') || '').split(',');
					
					const matchesOrg = selectedOrg === 'all' || orgTypes.includes(selectedOrg);
					const matchesCategory = selectedCategory === 'all' || categories.includes(selectedCategory);
					
					if (matchesOrg && matchesCategory) {
						container.style.display = '';
					} else {
						container.style.display = 'none';
					}
				});
			}
			
			filterButtons.forEach(button => {
				button.addEventListener('click', () => {
					const filterType = button.getAttribute('data-filter-type');
					const value = button.getAttribute('data-value');
					
					if (!filterType || !value) return;
					
					// Update active state for buttons in the same group
					document.querySelectorAll(`[data-filter-type="${filterType}"]`).forEach(btn => {
						btn.classList.remove('active');
					});
					button.classList.add('active');
					
					// Update selected filter
					if (filterType === 'organization') {
						selectedOrg = value;
					} else if (filterType === 'category') {
						selectedCategory = value;
					}
					
					filterClubs();
				});
			});
		</script>
	</body>
</html>
